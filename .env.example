# Скопировать в .env и заполнить. .env не коммитится.

# Корень, где на хосте лежат каталоги приложений (git-клоны):
# ai-box, ai-box-front, ai-box-data-registry, ai-box-mcp
APPS_ROOT=/var/www

# Домены этой копии (у каждой копии приложения — свои).
# Раскладка: корневой домен → редирект на app.; фронт на app., API на api.,
# админка на admin. CERT_NAME — имя lineage сертификата (по умолчанию = ROOT_DOMAIN).
ROOT_DOMAIN=ai-box.amulex.ru
FRONT_DOMAIN=app.ai-box.amulex.ru
API_DOMAIN=api.ai-box.amulex.ru
ADMIN_DOMAIN=admin.ai-box.amulex.ru
#CERT_NAME=ai-box.amulex.ru

# Внешний ASR-сервис голосовой диктовки: nginx проксирует ws-поток
# /api/.../asr/stream сюда после auth_request в Laravel. Адрес per-stend
# (для разных стендов может отличаться). Не задан → инертный дефолт
# 127.0.0.1:9 (локация неактивна, пока голос выключен в ai-box).
# doitai — выделенный GPU-бокс в LAN:
#ASR_WS_UPSTREAM=192.168.100.29:49153

# MariaDB
DB_ROOT_PASSWORD=
AI_BOX_DB_PASSWORD=
AI_BOX_DR_DB_PASSWORD=
AI_BOX_MCP_DB_PASSWORD=

# Redis (один инстанс на всех; распределение DB-индексов — в README)
REDIS_PASSWORD=

# browserless/chrome
BROWSERLESS_TOKEN=

# Подсеть ecosystem (проверить занятость: ip route). Дефолт 172.30.0.0/24.
#ECOSYSTEM_SUBNET=172.30.0.0/24
#ECOSYSTEM_GATEWAY=172.30.0.1

# Версия Qdrant: цель >= источника данных (см. docker-compose.yml)
#QDRANT_VERSION=v1.12.4

# Тюнинг под RAM хоста (дефолты безопасны для любого сервера):
# MariaDB innodb buffer pool — ~50-70% RAM выделенного под БД (doitai 16G → 4G).
#MARIADB_BUFFER_POOL=512M
# Redis граница памяти против OOM (политика volatile-lru — вытесняется только
# кэш с TTL, очереди сохраняются).
#REDIS_MAXMEMORY=512mb
