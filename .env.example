# Скопировать в .env и заполнить. .env не коммитится.

# Корень, где на хосте лежат каталоги приложений (git-клоны):
# ai-box, ai-box-front, ai-box-data-registry, ai-box-mcp
APPS_ROOT=/var/www

# Домены этой копии (у каждой копии приложения — свои).
# Раскладка: корневой домен → редирект на app.; фронт на app., API на api.,
# админка на admin. CERT_NAME — имя lineage сертификата (по умолчанию = ROOT_DOMAIN).
ROOT_DOMAIN=ai-box.amulex.ru
FRONT_DOMAIN=app.ai-box.amulex.ru
API_DOMAIN=api.ai-box.amulex.ru
ADMIN_DOMAIN=admin.ai-box.amulex.ru
#CERT_NAME=ai-box.amulex.ru

# MariaDB
DB_ROOT_PASSWORD=
AI_BOX_DB_PASSWORD=
AI_BOX_DR_DB_PASSWORD=
AI_BOX_MCP_DB_PASSWORD=

# Redis (один инстанс на всех; распределение DB-индексов — в README)
REDIS_PASSWORD=

# browserless/chrome
BROWSERLESS_TOKEN=
