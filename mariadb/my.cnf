[mysqld]
character-set-server = utf8mb4
collation-server     = utf8mb4_unicode_ci

# innodb_buffer_pool_size задаётся через env (--innodb-buffer-pool-size в
# command сервиса mariadb, дефолт 512M) — RAM у хостов разный (doitai 16G,
# addons-прод иной). Тут только безопасные, не зависящие от RAM параметры.
innodb_log_file_size            = 256M
innodb_flush_method             = O_DIRECT
# 2 = сбрасывать redo раз в секунду (не на каждый commit): заметно быстрее
# записи, риск — потеря ≤1с транзакций при аварии ОС. Приемлемо для этой
# нагрузки; для строгой durability вернуть 1.
innodb_flush_log_at_trx_commit  = 2
innodb_file_per_table           = 1
max_connections                 = 200
tmp_table_size                  = 64M
max_heap_table_size             = 64M

slow_query_log          = 1
slow_query_log_file     = /var/lib/mysql/slow.log
long_query_time         = 1

[client]
default-character-set = utf8mb4
